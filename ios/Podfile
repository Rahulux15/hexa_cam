platform :ios, '14.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get has been executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter/Generated.xcconfig and running flutter pub get again."
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      # permission_handler_apple: PermissionHandlerEnums.h defaults PERMISSION_* to 0.
      # Enable only the groups we use, or native request() is a no-op — no system sheet.
      # https://pub.dev/packages/permission_handler#ios
      next unless target.name == 'permission_handler_apple'

      defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS']
      defs = ['$(inherited)'] if defs.nil?
      defs = [defs] if defs.is_a?(String)
      %w[
        PERMISSION_CAMERA=1
        PERMISSION_MICROPHONE=1
        PERMISSION_PHOTOS=1
        PERMISSION_PHOTOS_ADD_ONLY=1
      ].each { |f| defs << f unless defs.include?(f) }
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs
    end
  end
end
